# YouTube Data API v3
# Get from: https://console.cloud.google.com/ → Enable YouTube Data API v3
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# Optional: additional YouTube API keys for quota rotation (comma-separated)
# YOUTUBE_API_KEYS_EXTRA=KEY2,KEY3

# Anthropic API
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Claude model to use (default is fine)
CLAUDE_MODEL=claude-sonnet-4-6

# How many recent videos to sample per channel for engagement metrics
MAX_VIDEOS_TO_SAMPLE=10

# Output directory for CSV/JSON/SQLite files
OUTPUT_DIR=output

# ---------------------------------------------------------------------------
# SMTP — required only if you use send_emails.py to send outreach
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=Your Name <you@example.com>

# Optional: override recipient address for test sends (--limit N)
# EMAIL_TEST_OVERRIDE=you@example.com
